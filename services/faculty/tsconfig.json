{
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "./dist",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "es2020",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "../../shared/**/*"]
}
